dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.output/
.vuepress/dist

# Vite
*.local

# Storybook
storybook-static/

# Testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo


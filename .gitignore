# =============================================================================
#  FUTURE VIP — .gitignore
#  Covers: Python, Node.js, Docker, IDE files, secrets, OS files
# =============================================================================

# ─────────────────────────────────────────────────────
#  SECRETS & ENVIRONMENT — NEVER COMMIT THESE
# ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local
*.pem
*.key
*.cert
*.crt
secrets/
credentials.json
service-account*.json
*_credentials.json

# ─────────────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-link
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env.bak
pyvenv.cfg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Type checking
.pytype/
pyrightconfig.json


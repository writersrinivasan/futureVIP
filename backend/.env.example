# Database
DATABASE_URL=postgresql://user:password@localhost:5432/future_vip
DATABASE_ECHO=False

# API Keys
OPENAI_API_KEY=sk-your-key-here
ADZUNA_API_ID=your-adzuna-id
ADZUNA_API_KEY=your-adzuna-key
JSEARCH_API_KEY=your-jsearch-key
GREENHOUSE_API_KEY=your-greenhouse-key
LEVER_API_KEY=your-lever-key

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRY=3600

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ChromaDB
CHROMA_DB_PATH=./data/chroma

# Environment
ENVIRONMENT=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
